:80 {
    handle /api/files* {
        respond 404
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    # for dev, for prod must point to static vite files...
    handle /files* {
    @denied not remote_ip 127.0.0.1 ::1
    respond @denied 403

    reverse_proxy frontend:5173
}

    handle {
        reverse_proxy frontend:5173
    }
}